<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>StrideNumberTextures</RootNamespace>
    <AssemblyName>StrideNumberTextures</AssemblyName>
  </PropertyGroup>

  <!-- Texture-pack library: 10 digit Texture assets (0-9), no code. Stride version comes from the Stride.* PackageReference. -->
  <ItemGroup>
    <PackageReference Include="Stride.Engine" Version="4.4.0.2" />
    <PackageReference Include="Stride.Core.Assets.CompilerApp" Version="4.4.0.2" IncludeAssets="build;buildTransitive" />
  </ItemGroup>

</Project>
